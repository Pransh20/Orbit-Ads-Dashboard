DATABASE_URL=postgresql://orbit:orbit@localhost:5432/orbit?schema=public
JWT_SECRET=replace-with-a-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-a-separate-long-random-secret
CLIENT_URL=http://localhost:5173
PORT=4000

META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:4000/api/meta/callback
META_API_VERSION=v25.0
# Stable local connection scopes. Add leads_retrieval/pages_manage_metadata only after Meta enables
# or approves those permissions for this app.
META_OAUTH_SCOPES=ads_read,ads_management,business_management,pages_show_list,pages_read_engagement
PUBLISHING_ENABLED=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Optional USD pricing inputs used only for the AiUsageLog cost estimate.
OPENAI_INPUT_COST_PER_1M=0
OPENAI_OUTPUT_COST_PER_1M=0

LOCAL_UPLOAD_PATH=uploads
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
