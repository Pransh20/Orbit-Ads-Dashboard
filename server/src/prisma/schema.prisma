generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CampaignStatus {
  DRAFT
  READY
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum AdStatus {
  DRAFT
  READY
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum AdFormat {
  SINGLE_IMAGE
  CAROUSEL
  VIDEO
  COLLECTION
}

enum CreativeType {
  IMAGE
  VIDEO
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String
  defaultCurrency String         @default("USD")
  timezone       String          @default("Europe/Berlin")
  createdAt      DateTime        @default(now())
  campaigns      Campaign[]
  metaConnection MetaConnection?
  aiUsageLogs    AiUsageLog[]
}

model Campaign {
  id                 String         @id @default(cuid())
  name               String
  objective          String
  goalLabel          String?
  businessDescription String?
  websiteUrl         String?
  brandName          String?
  parentCampaignId   String?
  relaunchReason     String?
  aiGenerated        Boolean        @default(false)
  aiReasoning        Json?
  status             CampaignStatus @default(DRAFT)
  dailyBudget        Decimal?       @db.Decimal(12, 2)
  lifetimeBudget     Decimal?       @db.Decimal(12, 2)
  currency           String         @default("USD")
  startDate          DateTime
  endDate            DateTime?
  specialAdCategory  String         @default("NONE")
  facebookCampaignId String?
  publishState       Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  createdById        String
  createdBy          User           @relation(fields: [createdById], references: [id])
  adSets             AdSet[]
  performanceSnapshots PerformanceSnapshot[]
  actions            ActionItem[]

  @@index([status])
  @@index([createdById])
  @@index([parentCampaignId])
}

model ActionItem {
  id               String   @id @default(cuid())
  campaignId       String
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  type             String
  priority         String   @default("RECOMMENDED")
  headline         String
  bodyText         String
  keyMetric        String?
  keyMetricValue   String?
  keyMetricVerdict String?
  actionLabel      String
  actionPayload    Json?
  status           String   @default("PENDING")
  generatedAt      DateTime @default(now())
  dismissedAt      DateTime?
  completedAt      DateTime?
  expiresAt        DateTime?

  @@index([campaignId, status])
  @@index([type, generatedAt])
  @@index([priority, generatedAt])
}

model AdSet {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  name            String
  audienceLabel   String?
  audienceReasoning String?
  status          AdStatus @default(DRAFT)
  targeting       Json
  optimizationGoal String
  billingEvent    String
  bidStrategy     String   @default("LOWEST_COST")
  bidAmount       Decimal? @db.Decimal(12, 2)
  facebookAdSetId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  ads             Ad[]

  @@index([campaignId])
}

model PerformanceSnapshot {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  fetchedAt   DateTime @default(now())
  dateRange   String
  impressions Int?
  reach       Int?
  clicks      Int?
  ctr         Float?
  spend       Float?
  cpm         Float?
  cpc         Float?
  frequency   Float?
  aiVerdict   String?
  aiSummary   String?
  rawMetaJson Json?

  @@index([campaignId, fetchedAt])
}

model Ad {
  id             String   @id @default(cuid())
  adSetId        String
  adSet          AdSet    @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  name           String
  status         AdStatus @default(DRAFT)
  format         AdFormat
  primaryText    String
  headline       String
  description    String?
  callToAction   String
  destinationUrl String
  pageId         String?
  instagramId    String?
  facebookAdId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  creatives      Creative[]

  @@index([adSetId])
}

model Creative {
  id           String       @id @default(cuid())
  adId         String
  ad           Ad           @relation(fields: [adId], references: [id], onDelete: Cascade)
  type         CreativeType
  fileName     String
  fileUrl      String
  mimeType     String
  fileSize     Int
  thumbnailUrl String?
  position     Int          @default(0)
  metaAssetId  String?
  uploadedAt   DateTime     @default(now())

  @@index([adId])
}

model MetaConnection {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken String
  adAccountId String
  pageId      String
  connectedAt DateTime @default(now())
  expiresAt   DateTime
  lastSyncedAt DateTime?
}

model AiUsageLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint    String
  requestHash String
  tokensUsed  Int
  costUsd     Float
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([requestHash])
}

model AiSettings {
  id                  String   @id @default(cuid())
  monthlyTokenBudget  Int      @default(500000)
  tokensUsedThisMonth Int      @default(0)
  lastResetAt         DateTime @default(now())
}
