NODE_ENV=production
PORT=4000

POSTGRES_USER=orbit
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=orbit
DATABASE_URL=postgresql://orbit:replace-with-a-strong-db-password@postgres:5432/orbit?schema=public

JWT_SECRET=replace-with-a-long-random-secret
TOKEN_ENCRYPTION_KEY=replace-with-a-different-long-random-secret

CLIENT_URL=https://orbit.ixclabs.com
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://orbit.ixclabs.com/api/meta/callback
META_API_VERSION=v25.0
META_OAUTH_SCOPES=ads_read,ads_management,business_management,pages_show_list,pages_read_engagement

# Keep false until the Meta publishing route has been verified against your ad account.
PUBLISHING_ENABLED=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_INPUT_COST_PER_1M=0
OPENAI_OUTPUT_COST_PER_1M=0

LOCAL_UPLOAD_PATH=/app/uploads
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
